# --- S3 (required) ---
S3_ENDPOINT_URL=https://minio.example.kz
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme

# --- BPM callback (required) ---
# base URL of the BPM host only; the result is POSTed to
# {BPM_CALLBACK_URL}/0/ServiceModel/AnGetTranscriptionResultService.svc/transcriptions/{CallRecordId}/result
BPM_CALLBACK_URL=http://mow2crm6:5000
# optional CSRF token; when set, sent to BPM as the BPMCSRF request header
#BPM_CSRF_TOKEN=

# --- Summarization ---
SUMMARY_ENABLED=true
# required when SUMMARY_ENABLED=true:
LLM_API_URL=http://vllm.example.kz:8000/v1
LLM_MODEL=qwen2.5-32b-instruct
#LLM_API_KEY=
#LLM_TIMEOUT_SECONDS=120
#SUMMARY_PROMPT=

# --- Whisper (compose passes these to whisper-api) ---
#WHISPER_MODEL=large-v3
#DEVICE=cuda            # cuda | cpu
#COMPUTE_TYPE=          # empty = auto (float16 for cuda, int8 for cpu)
#VAD_FILTER=true        # Silero VAD trims silence/hold music (fewer hallucinations)
#CONDITION_ON_PREVIOUS_TEXT=false  # false avoids repetition loops on phone audio
# open JSON object of faster-whisper transcribe options, merged over the tuned
# defaults; lets you tune any option without a rebuild. A supplied vad_parameters
# replaces the default one wholesale. Invalid JSON / non-object fails startup.
#TRANSCRIBE_OPTIONS={"beam_size":5,"temperature":0,"vad_parameters":{"min_silence_duration_ms":500}}
# optional TLS: set BOTH to serve HTTPS (paths inside the whisper-api container);
# unset = plain HTTP. Mount the certs via docker-compose (see the commented block),
# or set the paths without mounting anything — the container entrypoint then
# generates a self-signed cert there on startup (DOMAIN is its CN).
#SSL_CERTFILE=/certs/cert.pem
#SSL_KEYFILE=/certs/key.pem
#SSL_KEYFILE_PASSWORD=
#DOMAIN=llm.example.int
# setting this secures whisper-api's API; ai-service reads the same value
# via env_file and sends it as its own Bearer token automatically, so it
# no longer needs to stay empty
#WHISPER_API_KEY=

# --- Whisper (consumed by ai-service, not passed to whisper-api) ---
#WHISPER_TIMEOUT_SECONDS=600
#LANGUAGE=ru

# --- Service tuning (defaults shown) ---
#MAX_RETRIES=3
#RETRY_BACKOFF_CAP_SECONDS=300
#CALLBACK_TIMEOUT_SECONDS=30
#DB_PATH=/data/jobs.db
#AI_SERVICE_PORT=8080
#LOG_LEVEL=INFO
# listen ports are fixed inside compose (ai-service 8080, whisper-api 8000);
# the PORT env var applies only when running a service standalone
